#!/usr/bin/env bash
#
# Aborts `git push` if mate-campusclaw/ is out of sync with modules/*.
# Skipped automatically when the push range doesn't touch either tree.
# Bypass with `git push --no-verify` when you intentionally want to defer the sync.
#
# Activated repo-wide by:  git config core.hooksPath scripts/git-hooks

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="$ROOT/scripts/sync-mate-campusclaw.sh"

# Script may be missing on older branches — don't block those.
[ -x "$SCRIPT" ] || exit 0

# pre-push receives one line per ref being pushed:
#   <local_ref> <local_sha> <remote_ref> <remote_sha>
# Decide whether to run the (slow) sync check by inspecting only the diff
# of paths that matter (modules/* or mate-campusclaw/).
zero='0000000000000000000000000000000000000000'
needs_check=false
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${local_sha:-}" ] && continue
  [ "$local_sha" = "$zero" ] && continue                # branch deletion

  if [ "$remote_sha" = "$zero" ]; then
    # New branch on remote — compare against origin/main if it exists, else everything.
    base="$(git merge-base "$local_sha" origin/main 2>/dev/null || true)"
    range="${base:+$base..}$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  if git diff --name-only "$range" 2>/dev/null \
       | grep -qE '^(modules/|mate-campusclaw/|scripts/sync-mate)'; then
    needs_check=true
    break
  fi
done

$needs_check || exit 0

echo "[pre-push] modules/ or mate-campusclaw/ changed — checking mirror sync..."

# Run the sync in dry-run mode and look for itemize lines that mean a real change:
#   >f.s....  size differs       >f+++++++  new file
#   *deleting deletion           [would update] resource whitelist update
# (>f..t.... is mtime-only — ignored.)
PENDING="$(
  "$SCRIPT" --dry-run --no-verify 2>&1 \
    | grep -E '^(>f\.s|>f\+|\*deleting|\[would update\])' \
    || true
)"

if [ -z "$PENDING" ]; then
  echo "[pre-push] mate-campusclaw is in sync."
  exit 0
fi

count="$(printf '%s\n' "$PENDING" | wc -l | tr -d ' ')"
preview="$(printf '%s\n' "$PENDING" | head -10)"

cat >&2 <<EOF
[pre-push] mate-campusclaw is OUT OF SYNC with modules/* ($count change(s) pending).

Sample of what the sync would do:
$preview
$( [ "$count" -gt 10 ] && echo "... ($((count - 10)) more)" )

Resolve:
  ./scripts/sync-mate-campusclaw.sh
  git add mate-campusclaw
  git commit -m 'chore(mate): 同步 modules 到 mate-campusclaw'
  git push

Bypass (not recommended):
  git push --no-verify
EOF
exit 1
